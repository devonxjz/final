<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="LaptopPU" transaction-type="RESOURCE_LOCAL">
        <!-- Configure the Hibernate Provider -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <!-- List out all the Entities -->
        <class>com.example.entity.ChiTietHDBH</class>
        <class>com.example.entity.HoaDonBanHang</class>
        <class>com.example.entity.KhachHang</class>
        <class>com.example.entity.NhaCungCap</class>
        <class>com.example.entity.SanPham</class>
        <class>com.example.entity.ThanhToan</class>
        <class>com.example.entity.ChiTietHDBHId</class>

        <properties>
            <!-- Database Connection Properties -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/QLNVBCHLapTop"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="12345"/>

            <!-- Hibernate Properties -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>

            <!-- Tắt verbose SQL logging (dùng logback.xml để kiểm soát) -->
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>

            <!-- HikariCP Connection Pooling -->
            <property name="hibernate.connection.provider_class" value="org.hibernate.hikaricp.internal.HikariCPConnectionProvider"/>
            <property name="hibernate.hikari.minimumIdle" value="2"/>
            <property name="hibernate.hikari.maximumPoolSize" value="10"/>
            <property name="hibernate.hikari.idleTimeout" value="30000"/>
            <property name="hibernate.hikari.connectionTimeout" value="5000"/>
        </properties>
    </persistence-unit>
</persistence>
